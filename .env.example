# Database connection strings (use postgres for docker, localhost for local runtime)
POSTGRES_ASYNC_URI=postgresql+asyncpg://postgres:postgres@localhost:5432/darkatlas

# Cache configuration
REDIS_URI=redis://localhost:6379/0

# Security settings
JWT_SECRET=super-secret-jwt-key-for-darkatlas-asm-platform-2026

# Asset Management properties
STALE_THRESHOLD_DAYS=30
